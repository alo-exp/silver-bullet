# Secrets — never commit credentials to this repo
.env
.env.*
*.key
*.pem
id_rsa*
secrets.json

.DS_Store
site/new/
*.swp
*.swo
.worktrees/

# Claude Code runtime artifacts (per-session, per-user)
# Committed config (.claude/settings.json, .claude/commands/) stays tracked.
.claude/projects/
.claude/local/
.claude/.silver-bullet/
.claude/settings.local.json
.claude/worktrees/

# Session log artifacts (generated per-session by session-log-init.sh hook)
docs/sessions/

# E2E test app -- SB-generated artifacts (excluded from SB repo)
tests/test-app/node_modules/
tests/test-app/.planning/
tests/test-app/.silver-bullet.json
tests/forge-test-app/node_modules/
tests/test-app/silver-bullet.md
tests/test-app/CLAUDE.md
tests/test-app/docs/
tests/test-app/.github/

# Multi-agent phase coordination — runtime lock state (Phase 70)
# .phase-locks.json is the live lock state; .lock is the flock(1) sidecar.
# Both are per-checkout runtime state, never committed.
.planning/.phase-locks.json
.planning/.phase-locks.json.lock

# Composed-workflow tracker — runtime per-instance workflow files (Pass 2, v0.29.1)
# Active workflow files at .planning/workflows/<id>.md are local runtime state and
# never committed. The .archive/ subdir keeps completed workflow files for
# postmortem reference and is also gitignored.
.planning/workflows/

