#!/usr/bin/env bash
set -euo pipefail
trap 'exit 0' ERR

# SessionStart hook: inject Superpowers /using-superpowers skill into context.
# Write-always, idempotent — always injects, doesn't detect prior runs.
# This script does NOT read stdin.

# Security: restrict file creation permissions (user-only)
umask 0077

# Source symlink-write guard (SEC-02)
_lib_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd 2>/dev/null)" || _lib_dir=""
if [[ -n "$_lib_dir" && -f "$_lib_dir/nofollow-guard.sh" ]]; then
  # shellcheck source=lib/nofollow-guard.sh
  source "$_lib_dir/nofollow-guard.sh"
else
  sb_guard_nofollow() { [[ -L "$1" ]] && { printf 'ERROR: refusing to write through symlink: %s\n' "$1" >&2; exit 1; }; return 0; }
  sb_safe_write()    { [[ -L "$1" ]] && rm -f -- "$1"; return 0; }
fi

# Ensure user-scoped state directory exists
SB_STATE_DIR="${HOME}/.claude/.silver-bullet"
mkdir -p "$SB_STATE_DIR" 2>/dev/null || true

# ── Branch-scoped state reset ─────────────────────────────────────────────────
# Skill recordings are scoped to a git branch. When the branch changes between
# sessions, the full state is cleared — forcing a fresh workflow for the new branch.
# This prevents skills recorded for Feature A from satisfying enforcement for Feature B.
#
# Within the same branch: gsd-* markers are reset on each session start (forcing
# fresh GSD tracking per session), but skill recordings accumulate (so mid-feature
# work across multiple sessions is preserved).
state_file="${SB_STATE_DIR}/state"
branch_file="${SB_STATE_DIR}/branch"

# Env var override — allows tests to redirect state writes to a temp file
# without touching the live session state (same pattern as completion-audit.sh)
state_file="${SILVER_BULLET_STATE_FILE:-$state_file}"
# Security: validate path stays within ~/.claude/
case "$state_file" in
  "$HOME"/.claude/*) ;;
  *) state_file="${SB_STATE_DIR}/state" ;;
esac

# Env var override for branch file — allows tests to mock branch without
# touching the live ~/.claude/.silver-bullet/branch file.
branch_file="${SILVER_BULLET_BRANCH_FILE:-$branch_file}"
# Security: validate path stays within ~/.claude/
case "$branch_file" in
  "$HOME"/.claude/*) ;;
  *) branch_file="${SB_STATE_DIR}/branch" ;;
esac

# Detect current git branch (safe: validates characters, falls back to empty)
current_branch=""
current_branch=$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
if [[ -n "$current_branch" ]] && ! printf '%s' "$current_branch" | grep -qE '^[a-zA-Z0-9/_.-]+$'; then
  current_branch=""
fi

# Compare with stored branch
stored_branch=""
[[ -f "$branch_file" ]] && stored_branch=$(cat "$branch_file" 2>/dev/null || true)

if [[ -n "$current_branch" && ( ! -f "$branch_file" || -z "$stored_branch" ) ]]; then
  # Branch file absent or empty (first run, file deleted, or corrupted) — initialize
  # without wiping state.
  sb_guard_nofollow "$branch_file"
  printf '%s' "$current_branch" > "$branch_file"
  if [[ -f "$state_file" && ! -L "$state_file" ]]; then
    sed -i.bak '/^gsd-/d;/^quality-gate-stage-/d' "$state_file"
    rm -f -- "${state_file}.bak"
  fi
elif [[ -n "$current_branch" && "$current_branch" != "$stored_branch" ]]; then
  # Branch changed — full state reset for fresh workflow
  sb_safe_write "$state_file"
  rm -f -- "$state_file" 2>/dev/null || true
  sb_guard_nofollow "$branch_file"
  printf '%s' "$current_branch" > "$branch_file"
elif [[ -f "$state_file" && ! -L "$state_file" ]]; then
  # Same branch — reset session-specific markers only (gsd-* are transient
  # per-session GSD phase markers; quality-gate-stage-* must persist across
  # restarts so pre-release gate progress is not lost on session reconnect).
  sed -i.bak '/^gsd-/d' "$state_file"
  rm -f -- "${state_file}.bak"
fi


# Clean up trivial-change bypass from previous session
# Check config for custom trivial_file path, fall back to default
trivial_file="${SB_STATE_DIR}/trivial"
if command -v jq >/dev/null 2>&1; then
  search_dir="$PWD"
  while true; do
    if [[ -f "$search_dir/.silver-bullet.json" ]]; then
      cfg_trivial=$(jq -r '.state.trivial_file // ""' "$search_dir/.silver-bullet.json")
      [[ -n "$cfg_trivial" ]] && trivial_file="$cfg_trivial"
      break
    fi
    if [[ -d "$search_dir/.git" ]] || [[ "$search_dir" == "/" ]]; then break; fi
    search_dir=$(dirname "$search_dir")
  done
fi
# Security (SB-002/SB-003): validate trivial_file stays within ~/.claude/ before deletion
# Prevents path traversal via malicious .silver-bullet.json; reject symlinks too
case "$trivial_file" in
  "$HOME"/.claude/*) ;;
  *) trivial_file="${SB_STATE_DIR}/trivial" ;;
esac
[[ -L "$trivial_file" ]] && trivial_file="${SB_STATE_DIR}/trivial"
rm -f -- "$trivial_file" 2>/dev/null

# Warn visibly if jq is unavailable — enforcement will be disabled
if ! command -v jq >/dev/null 2>&1; then
  printf '{"hookSpecificOutput":{"message":"❌ Silver Bullet DISABLED — jq is required for all enforcement hooks. Install: brew install jq (macOS) / apt install jq (Linux). Without jq, quality gates, completion audit, and CI checks are inactive."}}'
  exit 0
fi

# Locate the Superpowers using-superpowers SKILL.md (glob, not find — faster and more restrictive)
# Security: validate resolved path stays within ~/.claude/plugins/cache/ before reading
sp_file=$(ls ~/.claude/plugins/cache/*/superpowers/*/skills/using-superpowers/SKILL.md 2>/dev/null | head -1 || true)
if [[ -n "${sp_file:-}" ]]; then
  _sp_resolved="$(cd "$(dirname "$sp_file")" 2>/dev/null && pwd)/$(basename "$sp_file")" || sp_file=""
  [[ "${_sp_resolved:-}" == "${HOME}/.claude/plugins/cache/"* ]] || sp_file=""
fi

# Locate Design plugin design-system SKILL.md
design_file=$(ls ~/.claude/plugins/cache/*/design/*/skills/design-system/SKILL.md 2>/dev/null | head -1 || true)
[[ -z "${design_file:-}" ]] && design_file=$(ls ~/.claude/plugins/cache/*/knowledge-work-plugins/*/design/skills/design-system/SKILL.md 2>/dev/null | head -1 || true)
if [[ -n "${design_file:-}" ]]; then
  _design_resolved="$(cd "$(dirname "$design_file")" 2>/dev/null && pwd)/$(basename "$design_file")" || design_file=""
  [[ "${_design_resolved:-}" == "${HOME}/.claude/plugins/cache/"* ]] || design_file=""
fi

# Locate SB core-rules.md (rules file installed alongside this hook)
# This is the SB equivalent of ~/.claude/core-values.yml — re-injected every session
# so enforcement rules survive context compaction.
# Security: co-located with hooks; plugin-dir write access implies hook modification
# access anyway. Path traversal defense: verify file resolves within plugin directory.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
core_rules_file="${script_dir}/core-rules.md"
# Fallback: try CLAUDE_PLUGIN_ROOT if script_dir heuristic fails
if [[ ! -f "$core_rules_file" ]] && [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
  core_rules_file="${CLAUDE_PLUGIN_ROOT}/hooks/core-rules.md"
fi
# Path traversal defense: reject if resolved path escapes plugin directory
if [[ -f "$core_rules_file" ]]; then
  _resolved_rules="$(cd "$(dirname "$core_rules_file")" && pwd)/$(basename "$core_rules_file")"
  if [[ "$_resolved_rules" != "${script_dir}/"* && "$_resolved_rules" != "${script_dir}" ]]; then
    core_rules_file=""
  fi
fi

# Build combined context
combined=""
if [[ -n "${sp_file:-}" ]]; then
  combined=$(cat "$sp_file")
fi
if [[ -n "${design_file:-}" ]]; then
  combined="${combined:+$combined

---

}Design plugin detected. Use /design:design-system and /design:ux-copy when the workflow requires UI/UX work."
fi

# Append core enforcement rules so they survive compaction (Tier 2 rule injection)
if [[ -f "$core_rules_file" ]]; then
  combined="${combined:+$combined

---

}$(cat "$core_rules_file")"
fi

# If nothing found, silent no-op
[[ -z "$combined" ]] && exit 0

# Escape for JSON and output
content=$(printf '%s' "$combined" | jq -Rs .)
printf '{"hookSpecificOutput":{"additionalContext":%s}}' "$content"
